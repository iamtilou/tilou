{
  "framework": "nextjs",
  "installCommand": "npm ci",
  "buildCommand": "next build",
  "redirects": [
    {
      "source": "/Batman-Rain.mp4",
      "destination": "/batman-rain.mp4",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/batman-rain.mp4",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
